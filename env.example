# Environment Configuration
NODE_ENV=production

# Frontend Configuration
REACT_APP_API_URL=http://localhost/api
REACT_APP_ENVIRONMENT=production

# Database Configuration (for future backend services)
POSTGRES_DB=widget_db
POSTGRES_USER=widget_user
POSTGRES_PASSWORD=widget_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend Services (when added)
DIRECTORY_SERVICE_URL=http://directory-service:8000
MATCHING_SERVICE_URL=http://matching-service:8000

# Security
JWT_SECRET=your-jwt-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# Monitoring
LOG_LEVEL=info
ENABLE_METRICS=true
